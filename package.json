{
  "name": "gks-v3",
  "version": "3.5.0",
  "description": "Genesis Knowledge System v3 — EVA Tri-Brain memory fabric (Phase 1 MVP)",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench:locomo": "tsx benchmarks/locomo.ts",
    "bench:longmemeval": "tsx benchmarks/longmemeval.ts",
    "bench:beam": "tsx benchmarks/beam.ts",
    "re-embed": "tsx scripts/msp/re-embed.ts",
    "pg-migrate": "tsx scripts/msp/pg-migrate.ts",
    "pg:up": "docker compose -f docker-compose.pg.yml up -d",
    "pg:down": "docker compose -f docker-compose.pg.yml down",
    "pg:reset": "docker compose -f docker-compose.pg.yml down -v && docker compose -f docker-compose.pg.yml up -d",
    "quickstart": "tsx examples/quickstart.ts"
  },
  "dependencies": {
    "hnswlib-node": "^3.0.0",
    "pg": "^8.20.0",
    "pg-copy-streams": "^7.0.0",
    "yaml": "^2.5.1"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "@types/pg": "^8.20.0",
    "@types/pg-copy-streams": "^1.2.5",
    "tsx": "^4.19.0",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}

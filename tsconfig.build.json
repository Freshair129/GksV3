{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "dist",
    "rootDir": ".",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "removeComments": false,
    "isolatedModules": true,
    "moduleResolution": "Bundler"
  },
  "include": ["src/**/*.ts", "bin/**/*.ts"],
  "exclude": [
    "node_modules",
    "dist",
    "test",
    "benchmarks",
    "examples",
    "scripts"
  ]
}
